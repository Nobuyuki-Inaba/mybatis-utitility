# Development tooling
.vscode/**
.vscode-test/**
.claude/**
.gitignore
.gitattributes
CLAUDE.md

# TypeScript source and configs
src/**
media/src/**
**/*.ts
**/tsconfig*.json

# Build artifacts — keep only the bundled outputs
out/**
!out/extension.js
**/*.map

# Webview scripts — keep bundled JS, exclude sources
media/src/**

# Keep only the two sql.js files needed at runtime (excludes debug/asm/browser variants)
node_modules/**
!node_modules/sql.js/package.json
!node_modules/sql.js/dist/sql-wasm.js
!node_modules/sql.js/dist/sql-wasm.wasm

# Package management
package-lock.json
